# Agent Runtime — environment (prefix: AGENTRT_)
# Defaults below target the docker-compose service names.

# MongoDB
AGENTRT_MONGO_URI=mongodb://mongodb:27017
AGENTRT_MONGO_DB=amendia

# RabbitMQ
AGENTRT_RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/

# Seeding
# AGENTRT_SEED_DIR=/src/backend/services/agent-runtime/seed/wire-repair-standard
AGENTRT_ENABLE_SEED_API=true
AGENTRT_SEED_ON_STARTUP=false

# Service
AGENTRT_HOST=0.0.0.0
AGENTRT_PORT=8083
AGENTRT_LOG_LEVEL=INFO
