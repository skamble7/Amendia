{
  "descriptor_version": "1.0",
  "capability_id": "cap.payment.assess_beneficiary_agentic",
  "version": "1.0.0",
  "title": "Assess repairability (agentic)",
  "description": "Read-only investigation via a bounded Deep Agents loop: name-match, payment-history search, and sanctions pre-check, emitting a repair_verdict with evidence[]. deep_agent kind — nemoclaw-only, HITL-gated, memoized (ADR-021).",
  "kind": "deep_agent",
  "side_effect": "read_only",
  "idempotent": true,
  "inputs": [
    {
      "name": "dossier",
      "schema": "art.payment.investigation_dossier@^1.0.0"
    }
  ],
  "outputs": [
    {
      "name": "beneficiary",
      "schema": "art.payment.repair_verdict@^1.0.0"
    }
  ],
  "runtime": {
    "kind": "deep_agent",
    "prompt_key": "prompt.payment.assess_beneficiary_agentic",
    "model_config_key": "dev.llm.nemoclaw.nim",
    "tools": ["name_match", "search_payment_history", "screen_party"],
    "structured_output": true,
    "budget": { "max_steps": 12, "max_tokens": 32000 }
  },
  "constraints": {
    "timeout_seconds": 180,
    "max_retries": 1,
    "min_hitl_mode": "review_after"
  },
  "owner": "platform",
  "status": "active"
}
