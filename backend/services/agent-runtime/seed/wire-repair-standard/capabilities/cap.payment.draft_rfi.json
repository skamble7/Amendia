{
  "descriptor_version": "1.0",
  "capability_id": "cap.payment.draft_rfi",
  "version": "1.0.0",
  "title": "Draft request for information",
  "description": "Pre-drafts an RFI to the originator or beneficiary bank when the case is inconclusive (assist for the manual Obtain-Info task).",
  "kind": "llm",
  "side_effect": "read_only",
  "idempotent": true,
  "inputs": [
    { "name": "dossier", "schema": "art.payment.investigation_dossier@^1.0.0" }
  ],
  "outputs": [
    { "name": "rfi", "schema": "art.payment.rfi_request@^1.0.0" }
  ],
  "runtime": {
    "kind": "llm",
    "prompt_key": "prompt.payment.draft_rfi",
    "model_config_key": "llm.payment.default",
    "structured_output": true
  },
  "constraints": { "timeout_seconds": 120, "max_retries": 2, "min_hitl_mode": "manual" },
  "owner": "platform",
  "status": "active"
}
