# Ingestor — environment (prefix: INGESTOR_)
# Defaults below target the docker-compose service names.

# MongoDB
INGESTOR_MONGO_URI=mongodb://mongodb:27017
INGESTOR_MONGO_DB=amendia
INGESTOR_MONGO_COLLECTION=ingestions

# RabbitMQ
INGESTOR_RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/
INGESTOR_RABBITMQ_QUEUE=ingestor.exception_raised.v1

# Exception store (the stub) fetch-back API
INGESTOR_STUB_BASE_URL=http://stub-exception-generator:8081

# Service
INGESTOR_HOST=0.0.0.0
INGESTOR_PORT=8082
INGESTOR_LOG_LEVEL=INFO
