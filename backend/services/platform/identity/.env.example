# Identity service — environment (prefix: IDENTITY_)
# Defaults below target the docker-compose service names.

# MongoDB
IDENTITY_MONGO_URI=mongodb://mongodb:27017
IDENTITY_MONGO_DB=amendia

# JIT provisioning status for newly-seen identities (active|disabled|pending)
IDENTITY_JIT_DEFAULT_STATUS=active

# Idempotent role-assignment seed (by email; materialised on first login)
IDENTITY_SEED_ON_STARTUP=true

# Shared internal token guarding POST /internal/resolve-principal (X-Amendia-Internal).
# Must equal every service's *_AUTH_INTERNAL_TOKEN.
IDENTITY_INTERNAL_TOKEN=dev-internal-token

# Auth (identity consumes amendia_auth for /me + admin guards)
IDENTITY_AUTH_ISSUER=http://localhost:8087/realms/amendia-dev
IDENTITY_AUTH_AUDIENCE=amendia-api
IDENTITY_AUTH_INTERNAL_TOKEN=dev-internal-token
# Tests/local only — never true in a real deployment.
IDENTITY_AUTH_AUTH_DISABLED=false

# Service
IDENTITY_HOST=0.0.0.0
IDENTITY_PORT=8086
IDENTITY_LOG_LEVEL=INFO
