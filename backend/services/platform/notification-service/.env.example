# Notification service — environment (prefix: NOTIFICATION_)
# Stateless SSE fan-out relay: consumes amendia.events and pushes thin signals.
# Defaults below target the docker-compose service names.

# Broker
NOTIFICATION_RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/

# SSE fan-out tuning
NOTIFICATION_CLIENT_QUEUE_MAXSIZE=100
NOTIFICATION_HEARTBEAT_SECONDS=20

# Auth (the SSE stream requires a valid bearer). Same values as every service —
# note the browser-facing issuer but the internal keycloak alias for JWKS.
NOTIFICATION_AUTH_ISSUER=http://localhost:8087/realms/amendia-dev
NOTIFICATION_AUTH_AUDIENCE=amendia-api
NOTIFICATION_AUTH_JWKS_URI=http://keycloak:8080/realms/amendia-dev/protocol/openid-connect/certs
NOTIFICATION_AUTH_IDENTITY_BASE_URL=http://identity:8086
NOTIFICATION_AUTH_INTERNAL_TOKEN=dev-internal-token
# Tests/local only — never true in a real deployment.
NOTIFICATION_AUTH_AUTH_DISABLED=false

# Service
NOTIFICATION_HOST=0.0.0.0
NOTIFICATION_PORT=8088
NOTIFICATION_LOG_LEVEL=INFO
NOTIFICATION_ENABLE_DEV_CORS=true
