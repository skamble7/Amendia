# Process Registry — environment (prefix: REGISTRY_)
# Defaults below target the docker-compose service names.

# MongoDB
REGISTRY_MONGO_URI=mongodb://mongodb:27017
REGISTRY_MONGO_DB=amendia

# Onboarding seed (drives the seed dataset through the real registry APIs)
# REGISTRY_SEED_DIR=/src/backend/services/agent-runtime/seed/wire-repair-standard
REGISTRY_SEED_ON_STARTUP=false

# /resolve active-pack cache TTL (seconds)
REGISTRY_RESOLVE_CACHE_TTL=30

# Service
REGISTRY_HOST=0.0.0.0
REGISTRY_PORT=8084
REGISTRY_LOG_LEVEL=INFO
