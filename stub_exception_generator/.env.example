# Stub Exception Generator — environment (prefix: STUBEXC_)
# Defaults below target the docker-compose service names.

# MongoDB
STUBEXC_MONGO_URI=mongodb://mongodb:27017
STUBEXC_MONGO_DB=amendia
STUBEXC_MONGO_COLLECTION=exceptions

# RabbitMQ
STUBEXC_RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/

# Service
STUBEXC_SERVICE_BASE_URL=http://localhost:8081
STUBEXC_DEFAULT_TENANT=bank-alpha
STUBEXC_HOST=0.0.0.0
STUBEXC_PORT=8081
STUBEXC_LOG_LEVEL=INFO
