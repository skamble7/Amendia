# The app is live-only and talks to the backend through same-origin /api/* paths,
# which the Vite dev proxy (dev) or nginx (built image) forward to the services.
# Override these only if you serve the services somewhere other than the proxy.
VITE_STUB_BASE=/api/stub
VITE_INGESTOR_BASE=/api/ingestor
VITE_RUNTIME_BASE=/api/runtime
VITE_REGISTRY_BASE=/api/registry
VITE_IDENTITY_BASE=/api/identity

# Used only by `pnpm gen:api` and the Vite proxy target (server-side, not exposed to the client).
VITE_STUB_URL=http://localhost:8081
VITE_INGESTOR_URL=http://localhost:8082
VITE_RUNTIME_URL=http://localhost:8083
VITE_REGISTRY_URL=http://localhost:8084
VITE_IDENTITY_URL=http://localhost:8086

# --- OIDC (PKCE) — the browser talks to Keycloak directly (NOT proxied) ---
# In production these point at the customer's own IdP (issuer + public SPA client).
VITE_OIDC_ISSUER=http://localhost:8087/realms/amendia-dev
VITE_OIDC_CLIENT_ID=amendia-webui
